#!/bin/sh
#
# This could be done with 'sort -V', but that is not POSIX.
#

sed -E -e '
s,^(.*)$,\1 \1,
s,^(|long-)([0-9])([-.]..*)$,\1000\2\3,
s,^(|long-)([0-9][0-9])([-.]..*)$,\100\2\3,
s,^(|long-)([0-9][0-9][0-9])([-.]..*)$,\10\2\3,
s,^(|long-)([0-9][0-9][0-9][0-9])(-.*)$,\1\2.0000\3,
s,^(|long-)([0-9][0-9][0-9][0-9])\.([0-9])([-.]..*)$,\1\2.000\3\4,
s,^(|long-)([0-9][0-9][0-9][0-9])\.([0-9][0-9])([-.]..*)$,\1\2.00\3\4,
s,^(|long-)([0-9][0-9][0-9][0-9])\.([0-9][0-9][0-9])([-.]..*)$,\1\2.0\3\4,
s,^(|long-)([0-9][0-9][0-9][0-9]\.[0-9][0-9][0-9][0-9])(-.*)$,\1\2.0000\3,
s,^(|long-)([0-9][0-9][0-9][0-9]\.[0-9][0-9][0-9][0-9])\.([0-9])([-.]..*)$,\1\2.000\3\4,
s,^(|long-)([0-9][0-9][0-9][0-9]\.[0-9][0-9][0-9][0-9])\.([0-9][0-9])([-.]..*)$,\1\2.00\3\4,
s,^(|long-)([0-9][0-9][0-9][0-9]\.[0-9][0-9][0-9][0-9])\.([0-9][0-9][0-9])([-.]..*)$,\1\2.0\3\4,
' | sort | sed -E -e 's,^[^ ]+ ,,'
