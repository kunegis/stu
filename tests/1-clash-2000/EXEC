#!/bin/sh
. ../../sh/test.sh

doo() { echo >&3 "$*" ; "$@" ; }

echo 0 >list.exitstatus

<LIST.stu cat |
sed -e '/^[[:space:]]*$/d;/^[[:space:]]*#/d' |
while IFS= read -r line ; do

	echo >&3 "LINE: $line"
	{
		echo "# Autogenerated by $0 on $(date)"
		echo
		echo "$line"
	} >list.tmp.stu

	doo rm -f ? list.err

	echo >&3 ../../bin/stu.test -f list.tmp.stu
	set +e
	../../bin/stu.test -f list.tmp.stu 2>list.err
	exitstatus=$?
	set -e
	[ "$exitstatus" = 2 ] || Error 'exit status'
	grep -q -F -e '-o' list.err || Error 'stderr'
done || exit 1

exit 0
