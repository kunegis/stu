% version 2.16

@all: @setup list.pdf;

list.pdf: A B
{
	cat A B >list.pdf
}

A = list.dir/A;
B = list.dir/B;

list.dir/$name: list.dir;

-p list.dir;

@setup
{
	mkdir list.target
	touch list.target/A
	touch list.target/B
	ln -s list.target list.dir
	touch A
	touch B

	../../sh/touch_old list.target/A 1
	../../sh/touch_old list.target/B 1

	ls -ld A B list.dir list.target list.target/*
}
