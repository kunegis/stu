#
# A longer example of newline-separated dynamic dependencies with the
# flag '-n'.  
#
# This is also an example of parameters contained in double quotes. 
#

@all:  A [ -n list.files ]; 

A = {correct}

>list.files
{
	../../sh/seq 99 | 
	sed -e 's,^,list.File ,'
}

>"list.File $k"
{
	echo "File no. $k" 
}

